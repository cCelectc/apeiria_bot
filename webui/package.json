{
  "name": "webui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm build-assets && pnpm write-build-meta",
    "build-assets": "pnpm type-check && pnpm build-only",
    "build-only": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:route-state": "node scripts/route-state-tests.mjs",
    "type-check": "vue-tsc --build --force",
    "write-build-meta": "APEIRIA_WEBUI_FRONTEND_DIR=webui python ../scripts/write-webui-build-meta.py --project-root ..",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@lucide/vue": "^1.16.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.5",
    "markdown-it": "^14.1.1",
    "markdown-it-task-lists": "^2.1.1",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.8",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.1"
  },
  "packageManager": "pnpm@11.2.2"
}
