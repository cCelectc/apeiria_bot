    "@vueuse/core": "^14.3.0",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.3",
    "lucide-vue-next": "^1.0.0",
    "markdown-it": "^14.1.1",
    "markdown-it-task-lists": "^2.1.1",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
